---
import type { Block } from '../lib/interfaces.js'
import TableOfContents from './notion-blocks/TableOfContents.astro';

export interface Props {
  heading: string
  blocks: Block[]
}
const { blocks } = Astro.props

// Notion側にTableOfContentsが存在しない場合でも作れるように仮想のアイテムを作成
const dummyBlock: Block = {
  Id: "",
  Type: "",
  HasChildren: false,
  TableOfContents: {
    Color: "gray"
  }
}

const headings = blocks.filter((b: Block) =>
    ['heading_1', 'heading_2', 'heading_3'].includes(b.Type)
  )
---

<div class="post-headline">
  <strong>目次</strong>
  <TableOfContents block={dummyBlock} headings={headings}/>
</div>

<style>
  /* position: sticky; でうまくやりたい〜 */
  .post-headline {
    max-width: 200px;
    width: 100%;
    position: fixed;
    top: 20%;
    right: 4px;
    margin-left: auto;
    margin-right: 0;
    padding: 1rem 1.5rem;
    background-color: #f6f6f6;
    border-radius: 0.5rem;
    z-index: 10;
  }
  @media (max-width: 1050px) {
    .post-headline {
      max-width: none;
      position: relative;
      margin: 1rem auto;
      width: 100%;
      padding: 0.8rem 1.5rem;
    }
  }
</style>
